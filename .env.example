# PostgreSQL connection string (Neon, local Docker, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Used by integration tests. Falls back to DATABASE_URL when not set.
# Point this at a separate test database to avoid clobbering dev data.
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/habitcoach_test

# HS256 secret for signing/verifying JWT access tokens.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-me-with-a-secure-random-value
